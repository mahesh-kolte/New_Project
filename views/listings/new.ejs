<% layout("layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <br /><br />
    <h3>Craete a new Listing</h3>
    <form action="/listings" method="post" class="needs-validation"  enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please provide a description.</div>
      </div>

       
      <div class="mb-3">
        <label class="form-label">Uplode Image</label>
        <input type="file" name="listing[image]" class="form-control"  required/>
      
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label class="form-label">Price</label>
          <input
             
            name="listing[price]"
            class="form-control"
            required
            
          />
          <div class="invalid-feedback">Please enter a valid price</div>
        </div>

        <div class="mb-3 col-md-8">
          <label class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please provide a country.</div>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please provide a location.</div>
      </div>
      <br /><br />

      <button type="submit" class="btn btn-dark add-btn">Add</button>
      <br /><br /><br />
    </form>
  </div>
</div>
